{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the teachers using the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier from Firebase Auth" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile picture" },
        "specialization": { "type": "string", "description": "Teacher's field of study (e.g., Mathematics, Arts)" },
        "bio": { "type": "string", "description": "Short biography of the teacher" },
        "role": { "type": "string", "enum": ["admin", "teacher"], "description": "User's role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created" }
      },
      "required": ["uid", "email"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post shared by a teacher in the community section.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique post ID" },
        "content": { "type": "string", "description": "Text content of the post" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Optional image URL for the post" },
        "authorUid": { "type": "string", "description": "UID of the teacher who created the post" },
        "authorName": { "type": "string", "description": "Display name of the author (denormalized)" },
        "authorPhoto": { "type": "string", "description": "Photo URL of the author (denormalized)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the post was created" },
        "likesCount": { "type": "number", "description": "Number of likes on the post" }
      },
      "required": ["content", "authorUid", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual teacher profiles."
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Shared posts in the teacher community."
    }
  }
}
